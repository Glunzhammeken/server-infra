# Skabelon for en kundes inventory. Kopiér til hosts.yml.
# Stakken kører på én maskine: Ansible ligger på serveren og
# konfigurerer den SAMME maskine via local connection. Derfor
# ingen IP, bruger eller SSH-nøgle her: der er ingen fjernforbindelse.
# Det kundespecifikke (domæne osv.) hører i group_vars/, ikke her.
all:
  hosts:
    server:
      ansible_connection: local
